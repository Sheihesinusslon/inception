DOMAIN_NAME=ngusev.42.fr

# Nginx settings
NGINX_PORT=443

# MySQL settings
MYSQL_DATABASE=wordpress
MYSQL_USER=wpuser
MYSQL_PORT=3306

# WordPress settings
WP_ADMIN_USER=ngusev_wp
WP_ADMIN_EMAIL=admin@ngusev.42.fr
WP_USER=ngusev_editor
WP_USER_EMAIL=editor@ngusev.42.fr
PHP_FPM_PORT=9000
PHP_FPM_MAX_CHILDREN=5
PHP_MEMORY_LIMIT=512M
PHP_UPLOAD_MAX_FILESIZE=64M
PHP_POST_MAX_SIZE=64M

# Redis settings
REDIS_PORT=6379
REDIS_MAXMEMORY=256mb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# FTP settings
FTP_USER=ftpuser
FTP_PORT=21
FTP_PASV_MIN=21000
FTP_PASV_MAX=21010
FTP_PASV_ADDRESS=127.0.0.1

# Flask website settings
FLASK_PORT=8080
FLASK_WORKERS=2

# Adminer settings
ADMINER_PORT=8081
ADMINER_VERSION=5.4.2

# Netdata settings
NETDATA_PORT=19999
